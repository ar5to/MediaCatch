<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingTop="8dp">

    <!-- Top accent bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- App icon -->
        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_download_circle"
            app:tint="@color/primary"
            android:contentDescription="App icon"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/dialog_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MediaCatch"
            android:textColor="@color/on_surface"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />

        <TextView
            android:id="@+id/dialog_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Version 1.0"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginVertical="16dp"
            android:background="@color/primary" />

        <TextView
            android:id="@+id/dialog_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/info_description"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by ar5to"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_github_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/github_button"
                android:layout_marginHorizontal="6dp"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_github"
                app:iconSize="16dp"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_sponsor_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="Follow"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_telegram"
                app:iconSize="16dp"
                app:iconTint="@color/primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom accent bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/primary" />

</LinearLayout>
